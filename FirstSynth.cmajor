}






processor ADSREnvelope
{
    input event (std::notes::NoteOn, std::notes::NoteOff) eventIn;
    input event Instrument::EnvParams envParamsIn;
    output stream float32 gainOut;
    output value int stateOut;


    Instrument::EnvParams params = Instrument::createEnvParams(0);
    float32 quickRelease = 0.02f;

    float32 targetLevel = 0.0f;
    float32 currentLevel = 0.0f;
    float32 releaseLevel = 0.0f;
    float32 velocity = 1.0f;
    
    int state = 0;  // 0=idle, 1=attack, 2=decay, 3=sustain, 4=release, 5=QuickRelease

    float32 stateTime = 0.0f;

    event envParamsIn(Instrument::EnvParams ep) {
        params.attack = ep.attack;
        params.decay = ep.decay;
        params.sustain = ep.sustain;
        params.release = ep.release;
    }

    event eventIn(std::notes::NoteOn e)
    {
        if (state != 0)
        {
            velocity = e.velocity;
            stateTime = 0.0f;
            targetLevel = velocity;
            releaseLevel = currentLevel;        
            setState(5); // Quick Release
        }
        else
        {
            velocity = e.velocity;
            setState(1);  // Attack
            stateTime = 0.0f;
            targetLevel = velocity;
        }
    }

    event eventIn(std::notes::NoteOff e)
    {
        setState(4);  // Release
        stateTime = 0.0f;
        releaseLevel = currentLevel;
    }

    void setState(int s) {
        state = s;
        stateOut <- state;
    }

    void main()
    {
        loop
        {
            if (state == 1)  // Attack
            {
                if (params.attack > 0.0f)
                    currentLevel = (stateTime / params.attack) * targetLevel;
                else
                    currentLevel = targetLevel;
                
                if (stateTime >= params.attack)
                {
                    setState(2);  // Decay
                    stateTime = 0.0f;
                    currentLevel = targetLevel;
                }
            }
            else if (state == 2)  // Decay
            {
                float32 decayAmount = targetLevel - (params.sustain * targetLevel);
                if (params.decay > 0.0f)
                    currentLevel = targetLevel - (stateTime / params.decay) * decayAmount;
                else
                    currentLevel = params.sustain * targetLevel;
                
                if (stateTime >= params.decay)
                {
                    setState(3);  // Sustain
                    currentLevel = params.sustain * targetLevel;
                }
            }
            else if (state == 3)  // Sustain
            {
                currentLevel = params.sustain * targetLevel;
            }
            else if (state == 4)  // Release
            {
                if (params.release > 0.0f)
                    currentLevel = releaseLevel * (1.0f - (stateTime / params.release));
                else
                    currentLevel = 0.0f;
                
                if (stateTime >= params.release)
                {
                    setState(0);  // Idle
                    currentLevel = 0.0f;
                }
            }
            else if (state == 5)  // QuickRelease 1ms New note
            {
                currentLevel = releaseLevel * (1.0f - (stateTime / quickRelease));
                
                if (stateTime >= quickRelease)
                {
                    setState(1);  // attack
                    currentLevel = 0.0f;
                    stateTime = 0.0f;
                }
            }
            else  // Idle
            {
                currentLevel = 0.0f;
            }

            gainOut <- currentLevel;

            stateTime += float32(processor.period);
            advance();
        }
    }
}

processor MyOscillator(float32 initialGain = 1.0, float intialFrequency = 3.0f)
{
    input {
        stream float32 mixSignalIn;       
        event float32 frequencyIn;
        event float32 gainIn;
        event Instrument::OscParams oscParamsIn;
        event void resetPhaseIn;
        value float32 waveShapeModulationIn;
        value float32 pitchModulationIn;
        value float32 panModulationIn;
        value float32 gainModulationIn;
        value float32 pitchBendIn;
    }

    output {
        stream float32 audioOut;
        stream float32 beforeGainOut;
        stream float32 phaseOut;
        value float32 panOut;
        value int32 oscSyncOut;
    }

    node {
        saturator = Saturator;
        smoothedPan = std::smoothing::SmoothedValueStream(0.05f, 0.0f);
        smoothedGain = std::smoothing::SmoothedValueStream(0.05f, 0.0f);
        smoothedPitchBend = std::smoothing::SmoothedValueStream(0.02f, 0.0f);
        smoothedWaveShape = std::smoothing::SmoothedValueStream(0.1f, 0.0f);
    }

    float32 phase;
    float32 previousPhase;
    float32 baseFrequency;
    float32 phaseIncrement;

    float lastFrequency;

    Instrument::OscParams oscParams;
    
    // Smoothed modulation values
    float32 smoothedPanValue = 0.0f;
    float32 smoothedGainValue = 0.0f;
    float32 smoothedPitchBendValue = 0.0f;

    void init() {
        phase = 0.0f;
        previousPhase = 0.0f;
        baseFrequency = intialFrequency;
        updatePhaseIncrement(baseFrequency);
    }


    void updatePhaseIncrement(float32 frequency)
    {
        // Apply transpose: multiply by 2^(transpose/12) where transpose is in semitones
        float32 octaveMultiplier = pow(2.0f, oscParams.transpose / 12.0f);
        // Apply detune: multiply by 2^(detune/1200) where detune is in cents
        float32 detuneMultiplier = pow(2.0f, oscParams.detune / 1200.0f);
        float32 finalFrequency = frequency * octaveMultiplier * detuneMultiplier;
        phaseIncrement = float32 (finalFrequency * processor.period);
    }

    event oscParamsIn (Instrument::OscParams params) {
        oscParams = params;
        panOut <- getModulatedPan(oscParams.pan, 0.0f);
        oscSyncOut <- params.sync;
        updatePhaseIncrement(baseFrequency);
        saturator.driveIn <- params.saturation;
        saturator.typeIn <- params.saturationType;
    }

    event frequencyIn(float newFrequency) {
        baseFrequency = newFrequency;
        updatePhaseIncrement(baseFrequency);
    }

    event resetPhaseIn() {
        phase = 0.0f;
    }

        float32 getModulatedPan(int32 basePan, float32 panMod) {
        // basePan is -100 to 100, panMod is -1.0 to 1.0
        float32 modulatedPan = basePan + (panMod * 100.0f);
        return max(-100.0f, min(100.0f, modulatedPan));
    }

    void main()
    {
        loop
        {
            // Update smoothing processors with current modulation values
            smoothedPan.in <- panModulationIn;
            smoothedGain.in <- gainModulationIn;
            smoothedPitchBend.in <- pitchBendIn;
            
            // Read smoothed modulation values from processors
            smoothedPanValue = smoothedPan.out;
            smoothedGainValue = smoothedGain.out;
            smoothedPitchBendValue = smoothedPitchBend.out;
            
            // Advance smoothing processors
            smoothedPan.advance();
            smoothedGain.advance();
            smoothedPitchBend.advance();
            
            // Interpolate between waveforms based on currentWaveShape (0-99)
            // 0=sine, 25=square, 50=sawtooth, 75=triangle
            float32 sample;

            smoothedWaveShape.in <- oscParams.waveshape + waveShapeModulationIn * 10.0f; // Modulate waveshape by up to 10 steps
            float32 waveValue = smoothedWaveShape.out;
            // Make sure wavaValue is within 0-99 after modulation
            // 101 must be 1, 102 must be 2, etc. to wrap around
            // -2 must be 98, -1 must be 99, etc.
            while (waveValue < 0.0f || waveValue >= 100.0f) {
                if (waveValue < 0.0f) {
                    waveValue = 100.0f + fmod(waveValue, 100.0f);
                } else {
                    waveValue = fmod(waveValue, 100.0f);
                }
            }
            smoothedWaveShape.advance();

            float32 modulatedFrequency = baseFrequency * pow(2.0f, pitchModulationIn / 12.0f + smoothedPitchBendValue);

            if (modulatedFrequency != lastFrequency) {
                updatePhaseIncrement(modulatedFrequency);
                lastFrequency = modulatedFrequency;
            }

            // Calculate blend based on value position
            if (waveValue <= 25) {
                float32 sineWave = std::oscillators::waveshape::sine(phase);
                float32 squareWave = std::oscillators::waveshape::square(phase);
                // Between sine and square
                float32 t = float32(waveValue) / 25.0f;
                sample = (1.0f - t) * sineWave + t * squareWave;
            } else if (waveValue <= 50) {
                float32 squareWave = std::oscillators::waveshape::square(phase);
                float32 sawtoothWave = std::oscillators::waveshape::sawtoothUp(phase);
                // Between square and sawtooth
                float32 t = float32(waveValue - 25) / 25.0f;
                sample = (1.0f - t) * squareWave + t * sawtoothWave;
            } else if (waveValue <= 75) {
                float32 sawtoothWave = std::oscillators::waveshape::sawtoothUp(phase);
                float32 triangleWave = std::oscillators::waveshape::triangle(phase);
                // Between sawtooth and triangle
                float32 t = float32(waveValue - 50) / 25.0f;
                sample = (1.0f - t) * sawtoothWave + t * triangleWave;
            } else {
                float32 triangleWave = std::oscillators::waveshape::triangle(phase);
                float32 sineWave = std::oscillators::waveshape::sine(phase);
                // Between triangle and sine (wrapping around)
                float32 t = float32(waveValue - 75) / 24.0f; // 75-99 = 24 steps
                sample = (1.0f - t) * triangleWave + t * sineWave;
            }
            
            beforeGainOut <- sample;
            saturator.audioIn <- (sample + mixSignalIn) * (oscParams.gain + smoothedGainValue);
            saturator.advance();
            audioOut <- saturator.audioOut;
            if (smoothedPanValue != 0.0f) {
                panOut <- getModulatedPan(oscParams.pan, smoothedPanValue);
            }
            phaseOut <- phase;
            previousPhase = phase;
            phase = fmod (phase + phaseIncrement, 1.0f);
            advance();
        }
    }
}


processor MyLfo(float32 initialShape = 0, float32 initialRate = 3.0f, float32 initialRampTime = 0.5f)
{
    input {
        event float32 rateIn;
        event int32 shapeIn;
        event void resetRampIn;
        event float32 rampIn;
        value float32 rateModulationIn;
    }

    output {
        stream float32 out;
    }

    node {
        lfo = std::oscillators::LFO;
    }


    float32 ramp;
    float32 rampIncrement;
    float32 lastRateModulationIn;
    float32 currentRate;

    void init() {
        lfo.rateHzIn <- initialRate;
        lfo.shapeIn <- initialShape;
        rampIncrement = float32(processor.period / initialRampTime);
        ramp = 0.0f;
    }

    event rateIn(float32 newRate) {
        currentRate = newRate;
        lfo.rateHzIn <- newRate;
    }

    event shapeIn(int32 newShape) {
        lfo.shapeIn <- float32(newShape);
    }

    event resetRampIn() {
        ramp = 0.0f;
    }

    event rampIn(float32 newRampTime) {
        rampIncrement = float32(processor.period / newRampTime);
    }

    void main()
    {
        loop
        {
            if (rateModulationIn != lastRateModulationIn) {
                lfo.rateHzIn <- currentRate + rateModulationIn;
                lastRateModulationIn = rateModulationIn;
            }

            if (ramp < 1.0f) {
                ramp = min(ramp + rampIncrement, 1.0f);
            }
            
            // Get LFO output and apply ramp
            var lfoOutput = lfo.out;
            out <- float32(lfoOutput) * ramp;
            lfo.advance();
            advance();
        }
    }

}


processor Voice
{
    input {
        event (std::notes::NoteOn, std::notes::NoteOff, std::notes::PitchBend, std::notes::Aftertouch, std::notes::Control) eventIn;
        event Instrument::Params paramsIn;
        event Instrument::OscParams oscParamsIn;
        event Instrument::LfoParams lfoParamsIn;
        event Instrument::EnvParams envParamsIn;
        event Instrument::MtxSourceUpdate mtxSourceUpdateIn;
        event Instrument::MtxMultiplierUpdate mtxMultiplierUpdateIn;
        event Instrument::MtxDestination1Update mtxDest1UpdateIn;
        event Instrument::MtxDestination2Update mtxDest2UpdateIn;
    }


    output {
        stream float<2> audioOut  [[ name: "Voice Audio Out" ]];        
    }


    node {
        oscillator = MyOscillator[3];
        envelopes = ADSREnvelope[3];
        lfos = MyLfo[3];

        filterLowPassL = std::filters::tpt::svf::Processor(std::filters::tpt::svf::Mode::lowPass, 2000.0f, 0.5f);
        filterLowPassR = std::filters::tpt::svf::Processor(std::filters::tpt::svf::Mode::lowPass, 2000.0f, 0.5f);

        filterHighPassL = std::filters::tpt::svf::Processor(std::filters::tpt::svf::Mode::highPass, 2000.0f, 0.5f);
        filterHighPassR = std::filters::tpt::svf::Processor(std::filters::tpt::svf::Mode::highPass, 2000.0f, 0.5f);

        noiseGeneratorWhite = std::noise::White;
        noiseGeneratorPink = std::noise::Pink;
        noiseGeneratorBrown = std::noise::Brown;
        
        smoothedCutoffProcessor = std::smoothing::SmoothedValueStream(0.05f, 2000.0f);
        smoothedResonanceProcessor = std::smoothing::SmoothedValueStream(0.05f, 0.5f);
    }



    const int32 NUM_ROWS = 16;
    Instrument::MtxRow[NUM_ROWS] rows;

    Instrument::Params params; // ??????
    float32 lfoPhase = 0.0f;
    float32 osc1PreviousPhase = 0.0f;
    float32[Instrument::MtxDestination::SIZE] matrixDestOut;
    float32 velocity = 0.0f;
    float32 keytrack = 0.0f;
    float32 aftertouch = 0.0f;
    float32 modWheel = 0.0f;
    

    void init() {
        for (wrap<NUM_ROWS> i) {
            rows[i].source = Instrument::MtxSource::NONE;
            rows[i].multiplier = 1.0f;
            rows[i].dest1 = Instrument::MtxDestination::NONE;
            rows[i].dest2 = Instrument::MtxDestination::NONE;
        }
    }


    event eventIn (std::notes::NoteOn e)
    {
        float32 baseFreq = std::notes::noteToFrequency (e.pitch);
        for (wrap<3> i) {
            oscillator[i].frequencyIn <- baseFreq;            
        }
        for (wrap<3> i) {
            envelopes[i].eventIn <- e;
            lfos[i].resetRampIn <- void;  // Trigger LFO ramp reset on note on
        }
        velocity = e.velocity;
        keytrack = (e.pitch - 64.0f) / 64.0f; 
    }

    event eventIn (std::notes::NoteOff e)
    {
        for (wrap<3> i) {
            envelopes[i].eventIn <- e;
        }
    }

    event eventIn (std::notes::PitchBend e)
    {
        // Handle pitch bend event
        float32 pitchBendValue = e.bendSemitones / 512.0f;
        
        // Apply pitch bend to oscillators
        for (wrap<3> i) {
            oscillator[i].pitchBendIn <- pitchBendValue;
        }
    }


    event eventIn (std::notes::Aftertouch e)
    {
        aftertouch = e.pressure;
    }

    event eventIn (std::notes::Control e)
    {
        if (e.control == 1) { // Modulation wheel
            modWheel = e.value;
        }
    }

    event paramsIn (Instrument::Params paramsIn) {
        params = paramsIn;
        
        // Send new filter parameter targets to smoothing processors
        smoothedCutoffProcessor.in <- paramsIn.filterCutoff;
        smoothedResonanceProcessor.in <- paramsIn.filterResonance;
    }

    event oscParamsIn (Instrument::OscParams oscParamsIn) {
        oscillator.at(oscParamsIn.index).oscParamsIn <- oscParamsIn;
    }

    event mtxSourceUpdateIn (Instrument::MtxSourceUpdate mtxSourceUpdate) {
        rows.at(mtxSourceUpdate.index).source = mtxSourceUpdate.source;     
    }

    event mtxMultiplierUpdateIn (Instrument::MtxMultiplierUpdate mtxMultiplierUpdate) {
        rows.at(mtxMultiplierUpdate.index).multiplier = mtxMultiplierUpdate.multiplier;     
    }

    event mtxDest1UpdateIn (Instrument::MtxDestination1Update mtxDest1Update) {
        rows.at(mtxDest1Update.index).dest1 = mtxDest1Update.dest1;     
    }

    event mtxDest2UpdateIn (Instrument::MtxDestination2Update mtxDest2Update) {
        rows.at(mtxDest2Update.index).dest2 = mtxDest2Update.dest2;     
    }
    
    event envParamsIn (Instrument::EnvParams envParamsIn) {
        envelopes.at(envParamsIn.index).envParamsIn <- envParamsIn;
    }

    event lfoParamsIn (Instrument::LfoParams lfoParamsIn) {
        lfos.at(lfoParamsIn.index).shapeIn <- lfoParamsIn.shape;
        lfos.at(lfoParamsIn.index).rateIn <- lfoParamsIn.rate;
        lfos.at(lfoParamsIn.index).rampIn <- lfoParamsIn.ramp;
    } 

    void computeMatrix() {
        // Matrix computation handled in Matrix processor

        // Reset destinations
        for (wrap<Instrument::MtxDestination::SIZE> j) {
            matrixDestOut[j] = 0.0f;  
        }
        

        // Process each row
        for (wrap<NUM_ROWS> i) {
            Instrument::MtxRow row = rows.at(i);
            if (row.multiplier != 0.0f && row.source != Instrument::MtxSource::NONE && (row.dest1 != Instrument::MtxDestination::NONE || row.dest2 != Instrument::MtxDestination::NONE)) {
                float32 sourceValue = 0.0f;

                if (row.source >= Instrument::MtxSource::LFO1 && row.source <= Instrument::MtxSource::LFO3) {
                    wrap<3> lfoIndex = wrap<3>(row.source - Instrument::MtxSource::LFO1);
                    sourceValue = lfos.at(lfoIndex).out;
                } else if (row.source >= Instrument::MtxSource::ENV1 && row.source <= Instrument::MtxSource::ENV3) {
                    wrap<3> envIndex = wrap<3>(row.source - Instrument::MtxSource::ENV1);
                    sourceValue = envelopes.at(envIndex).gainOut;
                } else if (row.source == Instrument::MtxSource::VELOCITY) {
                    sourceValue = velocity; 
                } else if (row.source == Instrument::MtxSource::KEYTRACK) {
                    sourceValue = keytrack; 
                } else if (row.source == Instrument::MtxSource::AFTERTOUCH) {
                    sourceValue = aftertouch; 
                } else if (row.source == Instrument::MtxSource::MOD_WHEEL) {
                    sourceValue = modWheel; 
                }
                float32 modulatedValue = sourceValue * row.multiplier;

                wrap<Instrument::MtxDestination::SIZE> dest1 = wrap<Instrument::MtxDestination::SIZE>(row.dest1);
                wrap<Instrument::MtxDestination::SIZE> dest2 = wrap<Instrument::MtxDestination::SIZE>(row.dest2);

                matrixDestOut[dest1] += modulatedValue;
                matrixDestOut[dest2] += modulatedValue;
            }
        }

        for (wrap<3> i) {
            envelopes.at(i).advance();
            lfos.at(i).advance();
        }   

    }

    void main() {
        loop {
            if (envelopes[0].stateOut == 0) {
                audioOut <- float<2>(0, 0);
            } else {
                float[3] panModulation;
                computeMatrix();



                for (wrap<3> i) {
                    wrap<Instrument::MtxDestination::SIZE> destWaveShape = wrap<Instrument::MtxDestination::SIZE>(Instrument::MtxDestination::OSC1_WAVESHAPE + i);
                    oscillator[i].waveShapeModulationIn <- matrixDestOut[destWaveShape];

                    wrap<Instrument::MtxDestination::SIZE> destPitch = wrap<Instrument::MtxDestination::SIZE>(Instrument::MtxDestination::OSC1_PITCH + i);
                    oscillator[i].pitchModulationIn <- matrixDestOut[destPitch];

                    wrap<Instrument::MtxDestination::SIZE> destPan = wrap<Instrument::MtxDestination::SIZE>(Instrument::MtxDestination::OSC1_PAN + i);
                    oscillator[i].panModulationIn <- matrixDestOut[destPan];

                    wrap<Instrument::MtxDestination::SIZE> destGain = wrap<Instrument::MtxDestination::SIZE>(Instrument::MtxDestination::OSC1_GAIN + i);
                    oscillator[i].gainModulationIn <- matrixDestOut[destGain];

                    wrap<Instrument::MtxDestination::SIZE> destLFO = wrap<Instrument::MtxDestination::SIZE>(Instrument::MtxDestination::LFO1_RATE + i);
                    if (matrixDestOut[destLFO] != 0.0f) {
                        lfos.at(i).rateModulationIn <- matrixDestOut[destLFO];  // Scale modulation to 0-10 Hz
                    }
                }

                // Handle oscillator sync: reset OSC2 phase when OSC1 wraps
                if (oscillator[1].oscSyncOut == 1) {
                    if (osc1PreviousPhase > oscillator[0].phaseOut) {
                        oscillator[1].resetPhaseIn <- void ;
                    }
                }

                osc1PreviousPhase = oscillator[0].phaseOut;


                // Calculate ring modulation signal of oscillator 2
                float32 rmSignal = oscillator[0].beforeGainOut * oscillator[1].beforeGainOut * params.rmAmount;
                oscillator[1].mixSignalIn <- rmSignal;

                // Calculate and send noise to oscillator 3 if needed
                if (params.osc3NoiseAmount > 0.0f) {
                    float32 noise = 0.0f;
                    
                    if (params.osc3NoiseType == 0) {
                        // White noise
                        noise = noiseGeneratorWhite.out * 2.0f - 1.0f;
                        noiseGeneratorWhite.advance();
                    } else if (params.osc3NoiseType == 1) {
                        // Pink noise
                        noise = noiseGeneratorPink.out * 2.0f - 1.0f;
                        noiseGeneratorPink.advance();
                    } else if (params.osc3NoiseType == 2) {
                        // Brown noise
                        noise = noiseGeneratorBrown.out * 2.0f - 1.0f;
                        noiseGeneratorBrown.advance();
                    }
                    
                    // Send (noise - oscillator) * amount to crossfade between oscillator and noise
                    // Result: (sample + (noise - sample) * amount) * gain = (sample * (1-amount) + noise * amount) * gain
                    // This ensures both oscillator and noise get the same gain and saturation applied
                    oscillator[2].mixSignalIn <- (noise - oscillator[2].beforeGainOut) * params.osc3NoiseAmount;
                } else {
                    // No noise, send zero
                    oscillator[2].mixSignalIn <- 0.0f;
                }
                               
                // Pan each oscillator to stereo using equal-power panning (optimized with sqrt)
                float<2> mixedOscillators = float<2>(0.0f, 0.0f);

                for (wrap<3> i) {
                    float panValue = oscillator[i].panOut / 100.0f;  // Normalize -1 to 1
                    float leftGain = sqrt((1.0f - panValue) * 0.5f);
                    float rightGain = sqrt((1.0f + panValue) * 0.5f);
                    
                    mixedOscillators[0] += oscillator[i].audioOut * leftGain;
                    mixedOscillators[1] += oscillator[i].audioOut * rightGain;
                }

                oscillator[0].advance();
                oscillator[1].advance();
                oscillator[2].advance();

                
                // Calculate Cutoff modulation
                float32 cutOffModulation =  matrixDestOut[Instrument::MtxDestination::FILTER_CUTOFF] * 1000.0f;
                float32 resonanceModulation = matrixDestOut[Instrument::MtxDestination::FILTER_RESONANCE];
                
                // Get smoothly interpolated filter parameters from processors
                float32 smoothedCutoffValue = smoothedCutoffProcessor.out;
                float32 smoothedResonanceValue = smoothedResonanceProcessor.out;
                
                // Advance smoothing processors
                smoothedCutoffProcessor.advance();
                smoothedResonanceProcessor.advance();
                                                
                // Pass through appropriate filter based on type (process stereo)
                float<2> filteredSignal;
                if (params.filterType == 0) {
                    // No filter, just pass through
                    filteredSignal = mixedOscillators;
                } else if (params.filterType == 1) {
                    float32 modulatedCutoff = clamp(smoothedCutoffValue + cutOffModulation, 20.0f, 20000.0f);
                    filterLowPassL.frequency <- modulatedCutoff;
                    filterLowPassR.frequency <- modulatedCutoff;
                    filterLowPassL.q <- max(0.1f, min(10.0f, smoothedResonanceValue + resonanceModulation));
                    filterLowPassR.q <- max(0.1f, min(10.0f, smoothedResonanceValue + resonanceModulation));
                    filterLowPassL.in <- mixedOscillators[0];
                    filterLowPassR.in <- mixedOscillators[1];
                    filteredSignal[0] = filterLowPassL.out;
                    filteredSignal[1] = filterLowPassR.out;
                    filterLowPassL.advance();
                    filterLowPassR.advance();
                } else if (params.filterType == 2) {
                    // Band-pass implemented as low-pass followed by high-pass
                    float32 modulatedCutoff = clamp(smoothedCutoffValue + cutOffModulation, 20.0f, 20000.0f);
                    filterLowPassL.frequency <- modulatedCutoff;
                    filterLowPassR.frequency <- modulatedCutoff;
                    filterLowPassL.q <- max(0.1f, min(10.0f, smoothedResonanceValue + resonanceModulation));
                    filterLowPassR.q <- max(0.1f, min(10.0f, smoothedResonanceValue + resonanceModulation));
                    filterHighPassL.frequency <- modulatedCutoff;
                    filterHighPassR.frequency <- modulatedCutoff;
                    filterHighPassL.q <- max(0.1f, min(10.0f, smoothedResonanceValue + resonanceModulation));
                    filterHighPassR.q <- max(0.1f, min(10.0f, smoothedResonanceValue + resonanceModulation));
                    
                    // Chain: oscillators -> low-pass -> high-pass
                    filterLowPassL.in <- mixedOscillators[0];
                    filterLowPassR.in <- mixedOscillators[1];
                    filterLowPassL.advance();
                    filterLowPassR.advance();
                    
                    filterHighPassL.in <- filterLowPassL.out;
                    filterHighPassR.in <- filterLowPassR.out;
                    filteredSignal[0] = filterHighPassL.out;
                    filteredSignal[1] = filterHighPassR.out;
                    filterHighPassL.advance();
                    filterHighPassR.advance();
                } else if (params.filterType == 3) {
                    float32 modulatedCutoff = clamp(smoothedCutoffValue + cutOffModulation, 20.0f, 20000.0f);
                    filterHighPassL.frequency <- modulatedCutoff;
                    filterHighPassR.frequency <- modulatedCutoff;
                    filterHighPassL.q <- max(0.1f, min(10.0f, smoothedResonanceValue + resonanceModulation));
                    filterHighPassR.q <- max(0.1f, min(10.0f, smoothedResonanceValue + resonanceModulation));
                    filterHighPassL.in <- mixedOscillators[0];
                    filterHighPassR.in <- mixedOscillators[1];
                    filteredSignal[0] = filterHighPassL.out;
                    filteredSignal[1] = filterHighPassR.out;
                    filterHighPassL.advance();
                    filterHighPassR.advance();
                }
                
                // Apply envelope and volume (stereo) using Envelope 1
                float<2> envelopedSignal = float<2>(envelopes[0].gainOut * filteredSignal[0] * params.mainGain,
                                                    envelopes[0].gainOut * filteredSignal[1] * params.mainGain);                                  
                audioOut <- envelopedSignal;
            }
            advance();
        }
    }

}


processor Saturator
{
    input stream float32 audioIn;
    output stream float32 audioOut;
    
    input event float32 driveIn;
    input event int typeIn;
    
    float32 drive = 1.0f;
    int type = 0;
    const float32 twopi = 2.0f * 3.14159f;
    
    event driveIn (float32 d) {
        drive = d;
    }
    
    event typeIn (int t) {
        type = t;
    }
    
    void main() {
        loop {
            float32 inSig = audioIn;
            float32 outSig = inSig;
            
            if (type != 0) {
                
                if (type == 1) {
                    // Convert 0-1 amount to drive (1.0-6.0)
                    float32 actualDrive = 1.0f + drive * 5.0f;
                    // Asymmetric (tube-style): tanh + linear component for even harmonics
                    float32 x = inSig * actualDrive;
                    outSig = (tanh(x) + 0.1f * x) / (1.0f + 0.1f * actualDrive);
                }
                else if (type == 2) {
                    // Wavefolder: folds the waveform back on itself for complex harmonics
                    float32 actualDrive = 0.5f + drive * 5.0f;
                    float32 x = inSig * actualDrive;
                    // Fold the signal using modulo and reflection
                    float32 folded = fmod(abs(x), 2.0f);
                    if (folded > 1.0f) {
                        folded = 2.0f - folded;
                    }
                    outSig = (folded - 0.5f) / (1.0f + actualDrive * 0.5f);
                }
                else if (type == 3) {
                    float32 actualDrive = 1.0f + drive * 2.0f;
                    outSig = float32(inSig + actualDrive / twoPi * sin (twopi * inSig));
                }
                else if (type == 4) {
                }
            }
            
            audioOut <- outSig;
            advance();
        }
    }
}


processor StereoSpread 
{
    input stream float<2> audioIn;
    output stream float<2> audioOut;
    
    input event float32 spreadAmount;

    node {
        smoothedSpread = std::smoothing::SmoothedValueStream(0.05f, 0.5f);
    }

    float stereoSpread;
    
    event spreadAmount (float32 a) {
        smoothedSpread.in <- a;
    }

    void main() {
        loop {
            // Get smoothed stereo spread value
            stereoSpread = smoothedSpread.out;
            smoothedSpread.advance();
            
            // Apply stereo spread (mid-side processing)
            float32 mid = (audioIn[0] + audioIn[1]) * 0.5f;
            float32 side = (audioIn[0] - audioIn[1]) * 0.5f;

            audioOut <- float<2>(mid + side * stereoSpread,
                                 mid - side * stereoSpread);
            advance();
        }
    }
}



processor Chorus
{
    // Chorus implemented by Claude
    input stream float<2> audioIn;
    output stream float<2> audioOut;
    
    input event float32 amountIn;
    
    node {
        smoothedAmount = std::smoothing::SmoothedValueStream(0.05f, 0.0f);
    }
    
    float32 amount = 0.0f;
    
    // Chorus parameters
    let maxDelayMs = 60.0f;

    let baseDelayMs = float[4] (15, 25, 35, 45 );
    let modDepthMs = float[4] (2.5, 3.5, 3.5, 2.5);
    let lfoRate = float[4] ( 0.8f, 0.9f, 1.0f, 1.1f);
    
    // Calculate delay buffer size
    // let maxDelaySamples = int(float(processor.frequency) * maxDelayMs / 1000.0f);
    const int32 maxDelaySamples =  int(48000.0f * maxDelayMs / 1000.0f); // Fixed size for efficiency
    float32[maxDelaySamples] delayBufferL;
    float32[maxDelaySamples] delayBufferR;
    int writePos = 0;
    
    float32[4] lfoPhase = (0.0f, 0.25f, 0.5f, 0.75f);

    let lfoInc = float[4] (lfoRate[0] / float32(processor.frequency), lfoRate[1] / float32(processor.frequency),
        lfoRate[2] / float32(processor.frequency), lfoRate[3] / float32(processor.frequency));


    event amountIn (float32 a) {
        smoothedAmount.in <- a;
    }
    
    void main() {
        loop {
            // Get smoothed amount value
            amount = smoothedAmount.out;
            smoothedAmount.advance();
            
            // Write input to delay buffers
            if (amount > 0) {
                delayBufferL.at(writePos) = audioIn[0];
                delayBufferR.at(writePos) = audioIn[1];
                
                float32 wetL = 0.0f;
                float32 wetR = 0.0f;

                for (int i = 0; i< 4; i++) {
                    lfoPhase.at(i) = fmod(lfoPhase.at(i) + lfoInc.at(i), 1.0f);

                    // Calculate modulated delay times
                    float32 lfoVal = sin(lfoPhase.at(i) * float32(twoPi));
                    float32 delayMs = baseDelayMs.at(i) + lfoVal * modDepthMs.at(i);
                    // Convert to samples
                    float32 delaySamples = delayMs * float32(processor.frequency) / 1000.0f;
                
                    // Calculate read positions with linear interpolation
                    float32 readPos = float32(writePos) - delaySamples;
                    if (readPos < 0.0f) readPos += float32(maxDelaySamples);

                    // Linear interpolation for smoother modulation
                    int readIdx = int(readPos) % maxDelaySamples;
                    int readIdxNext = (readIdx + 1) % maxDelaySamples;
                    float32 frac = readPos - floor(readPos);
                                        
                    // Read from delay buffers with interpolation
                    float32 delayedL = delayBufferL.at(readIdx) * (1.0f - frac) + delayBufferL.at(readIdxNext) * frac;
                    float32 delayedR = delayBufferR.at(readIdx) * (1.0f - frac) + delayBufferR.at(readIdxNext) * frac;
                    
                    // Mix the chorus voices
                    wetL += delayedL * 0.25f;
                    wetR += delayedR * 0.25f;
                }

               
                // Dry/wet mix based on amount (0 = dry, 1 = wet)
                float32 outL = audioIn[0] * (1.0f - amount/2) + wetL * amount;
                float32 outR = audioIn[1] * (1.0f - amount/2) + wetR * amount;
                
                audioOut <- float<2>(outL, outR);
                
                // Advance write position
                writePos = (writePos + 1) % maxDelaySamples;
            } else {
                audioOut <- audioIn;            
            }
            advance();
        }
    }
}
