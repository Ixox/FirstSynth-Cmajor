
// Here's a very simple synth

graph FirstSynth  [[ main ]]
{
    input { 
        event std::midi::Message midiIn  [[ name: "MIDI input" ]];
        paramsProcessor.*;
    }
    output {
        stream float<2> audioOut  [[ name: "Audio Out" ]];
    }

    node {
        voices = Voice[16];
        voiceAllocator = std::voices::VoiceAllocator(16);
        paramsProcessor = Instrument::Processor;
        chorusProcessor = Chorus;
        stereoSpreadProcessor = StereoSpread;
    }

    connection {
        midiIn -> std::midi::MPEConverter -> voiceAllocator;
        voiceAllocator.voiceEventOut -> voices.eventIn;

        voices.audioOut -> stereoSpreadProcessor.audioIn;
        stereoSpreadProcessor.audioOut -> chorusProcessor.audioIn;
        chorusProcessor.audioOut -> audioOut;

        paramsProcessor.paramsOut -> voices.paramsIn;
        paramsProcessor.oscParamsOut -> voices.oscParamsIn;
        
        paramsProcessor.envParamsOut -> voices.envParamsIn;
        paramsProcessor.lfoParamsOut -> voices.lfoParamsIn;
        paramsProcessor.mtxSourceUpdateOut -> voices.mtxSourceUpdateIn;
        paramsProcessor.mtxMultiplierUpdateOut -> voices.mtxMultiplierUpdateIn;
        paramsProcessor.mtxDest1UpdateOut -> voices.mtxDest1UpdateIn;
        paramsProcessor.mtxDest2UpdateOut -> voices.mtxDest2UpdateIn;
        
        paramsProcessor.chorusAmountOut -> chorusProcessor.amountIn;
        paramsProcessor.stereoSpreadOut -> stereoSpreadProcessor.spreadAmount;

    }
}


namespace Instrument {

    namespace MtxSource {
        const int NONE = 0;
        const int LFO1 = 1;
        const int LFO2 = 2;
        const int LFO3 = 3;
        const int ENV1 = 4;
        const int ENV2 = 5;
        const int ENV3 = 6;
        const int KEYTRACK = 7;
        const int VELOCITY = 8;
        const int AFTERTOUCH = 9;
        const int MOD_WHEEL = 10;
        const int SIZE = 11;
    }

    namespace MtxDestination {
        const int NONE = 0;
        const int OSC1_WAVESHAPE = 1;
        const int OSC2_WAVESHAPE = 2;
        const int OSC3_WAVESHAPE = 3;
        const int OSC1_PITCH = 4;
        const int OSC2_PITCH = 5;
        const int OSC3_PITCH = 6;
        const int OSC1_PAN = 7;
        const int OSC2_PAN = 8;
        const int OSC3_PAN = 9;
        const int OSC1_GAIN = 10;
        const int OSC2_GAIN = 11;
        const int OSC3_GAIN = 12;
        const int FILTER_CUTOFF = 13;
        const int FILTER_RESONANCE = 14;
        const int LFO1_RATE = 15;
        const int LFO2_RATE = 16;
        const int LFO3_RATE = 17;
        const int SIZE = 18;
    }

    struct MtxRow {
        int32 source;
        float32 multiplier;
        int32 dest1;
        int32 dest2;
    }

    struct MtxSourceUpdate {
        int32 index;
        int32 source;
    } 

    struct MtxMultiplierUpdate {
        int32 index;
        float32 multiplier;
    }

    struct MtxDestination1Update {
        int32 index;
        int32 dest1;
    }

    struct MtxDestination2Update {
        int32 index;
        int32 dest2;
    }

    struct EnvParams {
        int32 index;
        float32 attack;
        float32 decay;
        float32 sustain;
        float32 release;
    }

    struct LfoParams {
        int32 index;
        float32 rate;
        int32 shape; 
        float32 ramp;               
    }

    struct OscParams {
        int32 index;
        float32 transpose;
        float32 detune;
        float32 gain;
        int32 waveshape;
        float32 saturation;
        int32 saturationType;
        int32 pan;
        int32 sync;
    }

    struct Params {     
        // Ring Modulation
        float32 rmAmount;
        
        // Oscillator 3 Noise
        float32 osc3NoiseAmount;
        int32 osc3NoiseType;
        
        // Filter
        int32 filterType;
        float32 filterCutoff;
        float32 filterResonance;
        
        // Stereo Effects
        float32 stereoSpread;
        float32 chorusAmount;
        
        // Global
        float32 mainGain;
    }

    Params createParams() {
        Params p;
        // Ring Modulation
        p.rmAmount = 0.0f;
        
        // Oscillator 3 Noise
        p.osc3NoiseAmount = 0.0f;
        p.osc3NoiseType = 0;
        
        // Filter
        p.filterCutoff = 2000.0f;
        p.filterResonance = 0.5f;
        p.filterType = 0;  // 0 = lowPass, 1 = highPass
               
        // Stereo Effects
        p.stereoSpread = 0.5f;
        p.chorusAmount = 0.0f;
        
        // Global
        p.mainGain = 0.0f;
        return p;
    }

    EnvParams createEnvParams(int index) {
        EnvParams env;
        env.index = index;
        env.attack = 0.01f;
        env.decay = 0.1f;
        env.sustain = 0.3f;
        env.release= 1.0f;
        return env;
    }

    LfoParams createLfoParams(int32 index) {
        LfoParams lfo;
        lfo.index = index;
        lfo.rate = 1.0f;
        lfo.shape = 0;
        lfo.ramp = 0.0f;
        return lfo;
    }

    OscParams createOscParams(int32 index) {
        OscParams p;
        p.index = index;
        p.transpose = 0.0f;
        p.detune = 0.0f;
        p.gain = 0.8f;
        p.waveshape = 0;
        p.pan = 0;
        p.saturation = 0.0f;
        p.saturationType = 0;
        return p;
    }

    MtxRow createMtxRow(int i1, int i2) {
        MtxRow row;
        row.source = MtxSource::NONE;
        row.multiplier = 1.0f;
        row.dest1 = MtxDestination::NONE;
        row.dest2 = MtxDestination::NONE;
        return row;
    }

    struct ParamOut {
        int32 paramId;
        int32 newValue;
    }


    processor Processor {

        // input event (std::notes::Control) controlEventIn;

        // Oscillator 1
        input {
            event float32 osc1Transpose       [[ name: "Osc 1 Transpose", min: -48, max: 48, step: 1, init: 0 ]];
            event int osc1Detune              [[ name: "Osc 1 Detune", min: -50, max: 50, step: 1, init: 0 ]];
            event int osc1Gain                [[ name: "Osc 1 Gain", min: 0, max: 141, step: 1, init: 80 ]];
            event int osc1Waveshape           [[ name: "Osc 1 Waveshape", min: 0, max: 99, step: 1, init: 15 ]];
            event int osc1Pan                 [[ name: "Osc 1 Pan", min: -100, max: 100, step: 1, init: 0 ]];
            event int osc1Saturation          [[ name: "Osc 1 Saturation", min: 0, max: 100, step: 1, init: 0 ]];
            event int osc1SaturationType      [[ name: "Osc 1 Saturation Type", min: 0, max: 3, step: 1, init: 0 ]];
            
            // Oscillator 2
            event float32 osc2Transpose       [[ name: "Osc 2 Transpose", min: -48, max: 48, step: 1, init: 0 ]];
            event int osc2Detune              [[ name: "Osc 2 Detune", min: -50, max: 50, step: 1, init: 5 ]];
            event int osc2Gain                [[ name: "Osc 2 Gain", min: 0, max: 141, step: 1, init: 50 ]];
            event int osc2Waveshape           [[ name: "Osc 2 Waveshape", min: 0, max: 99, step: 1, init: 0 ]];
            event int osc2Sync                [[ name: "Osc 2 Sync", min: 0, max: 1, step: 1, init: 0 ]];
            event int osc2Pan                 [[ name: "Osc 2 Pan", min: -100, max: 100, step: 1, init: 0 ]];
            event int osc2Saturation          [[ name: "Osc 2 Saturation", min: 0, max: 100, step: 1, init: 0 ]];
            event int osc2SaturationType      [[ name: "Osc 2 Saturation Type", min: 0, max: 3, step: 1, init: 0 ]];
            
            // Oscillator 3
            event float32 osc3Transpose       [[ name: "Osc 3 Transpose", min: -48, max: 48, step: 1, init: 0 ]];
            event int osc3Detune              [[ name: "Osc 3 Detune", min: -50, max: 50, step: 1, init: 0 ]];
            event int osc3Gain                [[ name: "Osc 3 Gain", min: 0, max: 141, step: 1, init: 30 ]];
            event int osc3Waveshape           [[ name: "Osc 3 Waveshape", min: 0, max: 99, step: 1, init: 0 ]];
            event int osc3Pan                 [[ name: "Osc 3 Pan", min: -100, max: 100, step: 1, init: 0 ]];
            event int osc3Saturation          [[ name: "Osc 3 Saturation", min: 0, max: 100, step: 1, init: 0 ]];
            event int osc3SaturationType      [[ name: "Osc 3 Saturation Type", min: 0, max: 3, step: 1, init: 0 ]];
            event int osc3NoiseAmount         [[ name: "Osc 3 Noise Amount", min: 0, max: 100, step: 1, init: 0 ]];
            event int osc3NoiseType           [[ name: "Osc 3 Noise Type", min: 0, max: 2, step: 1, init: 0 ]];
          
            // Ring Modulation
            event int rmAmount                [[ name: "RM Amount", min: 0, max: 100, step: 1, init: 0 ]];
            
            // Filter
            event int filterCutoff            [[ name: "Filter Cutoff", min: 20, max: 20000, step: 1, init: 2000 ]];
            event int filterResonance         [[ name: "Filter Resonance", min: 20, max: 1000, step: 1, init: 50 ]];
            event int filterType              [[ name: "Filter Type", min: 0, max: 3, step: 1, init: 1 ]];

            // Env 1,2,3
            event int env1Attack               [[ name: "Env 1 Attack", min: 1, max: 5000, step: 1, init: 10 ]];
            event int env1Decay                [[ name: "Env 1 Decay", min: 1, max: 5000, step: 1, init: 100 ]];
            event int env1Sustain              [[ name: "Env 1 Sustain", min: 0, max: 100, step: 1, init: 70 ]];
            event int env1Release              [[ name: "Env 1 Release", min: 1, max: 5000, step: 1, init: 300 ]];
            event int env2Attack               [[ name: "Env 2 Attack", min: 1, max: 5000, step: 1, init: 10 ]];
            event int env2Decay                [[ name: "Env 2 Decay", min: 1, max: 5000, step: 1, init: 100 ]];
            event int env2Sustain              [[ name: "Env 2 Sustain", min: 0, max: 100, step: 1, init: 100 ]];
            event int env2Release              [[ name: "Env 2 Release", min: 1, max: 5000, step: 1, init: 300 ]];
            event int env3Attack               [[ name: "Env 3 Attack", min: 1, max: 5000, step: 1, init: 10 ]];
            event int env3Decay                [[ name: "Env 3 Decay", min: 1, max: 5000, step: 1, init: 100 ]];
            event int env3Sustain              [[ name: "Env 3 Sustain", min: 0, max: 100, step: 1, init: 100 ]];
            event int env3Release              [[ name: "Env 3 Release", min: 1, max: 5000, step: 1, init: 300 ]];

            // 'WaveShape', 'Rate', 'Ramp' for LFOs would be handled similarly
            event int lfo1Rate                 [[ name: "LFO 1 Rate", min: 1, max: 601, step: 1, init: 50 ]];
            event int lfo2Rate                 [[ name: "LFO 2 Rate", min: 1, max: 601, step: 1, init: 50 ]];
            event int lfo3Rate                 [[ name: "LFO 3 Rate", min: 1, max: 601, step: 1, init: 50 ]];
            // Ramp
            event int lfo1Ramp                 [[ name: "LFO 1 Ramp", min: 0, max: 5000, step: 1, init: 0 ]];
            event int lfo2Ramp                 [[ name: "LFO 2 Ramp", min: 0, max: 5000, step: 1, init: 0 ]];
            event int lfo3Ramp                 [[ name: "LFO 3 Ramp", min: 0, max: 5000, step: 1, init: 0 ]];
            // WaveShape
            event int lfo1WaveShape            [[ name: "LFO 1 WaveShape", min: 0, max: 5, step: 1, init: 0 ]];
            event int lfo2WaveShape            [[ name: "LFO 2 WaveShape", min: 0, max: 5, step: 1, init: 0 ]];
            event int lfo3WaveShape            [[ name: "LFO 3 WaveShape", min: 0, max: 5, step: 1, init: 0 ]];
            
            // Stereo Effects
            event int stereoSpread            [[ name: "Stereo Spread", min: 0, max: 100, step: 1, init: 50 ]];
            event int chorusAmount            [[ name: "Chorus Amount", min: 0, max: 100, step: 1, init: 0 ]];
            
            // Global
            event int mainGain                 [[ name: "mainGain", min: 0, max: 141, step: 1, init: 100, cc:21 ]];

            // Matrix 
            // Row 1
            event int mtxRow1Source                 [[ name: "Mtx Row 1 Src", min: 0, max: MtxSource::SIZE-1, step: 1, init: MtxSource::LFO1 ]];
            event float mtxRow1Multiplier           [[ name: "Mtx Row 1 Mult", min: -10, max: 10, step: .01, init: 1 ]];
            event int mtxRow1Dest1                  [[ name: "Mtx Row 1 Dest 1", min: 0, max: MtxDestination::SIZE-1, step: 1, init: 0 ]];
            event int mtxRow1Dest2                  [[ name: "Mtx Row 1 Dest 2", min: 0, max: MtxDestination::SIZE-1, step: 1, init: 0 ]];
            // Row 2
            event int mtxRow2Source                 [[ name: "Mtx Row 2 Src", min: 0, max: MtxSource::SIZE-1, step: 1, init: MtxSource::LFO2 ]];
            event float mtxRow2Multiplier           [[ name: "Mtx Row 2 Mult", min: -10, max: 10, step: .01, init: 1 ]];
            event int mtxRow2Dest1                  [[ name: "Mtx Row 2 Dest 1", min: 0, max: MtxDestination::SIZE-1, step: 1, init: 0 ]];
            event int mtxRow2Dest2                  [[ name: "Mtx Row 2 Dest 2", min: 0, max: MtxDestination::SIZE-1, step: 1, init: 0 ]];
                // Row 3
            event int mtxRow3Source                 [[ name: "Mtx Row 3 Src", min: 0, max: MtxSource::SIZE-1, step: 1, init: MtxSource::LFO3 ]];
            event float mtxRow3Multiplier           [[ name: "Mtx Row 3 Mult", min: -10, max: 10, step: .01, init: 1 ]];
            event int mtxRow3Dest1                  [[ name: "Mtx Row 3 Dest 1", min: 0, max: MtxDestination::SIZE-1, step: 1, init: 0 ]];
            event int mtxRow3Dest2                  [[ name: "Mtx Row 3 Dest 2", min: 0, max: MtxDestination::SIZE-1, step: 1, init: 0 ]];
            // Row 4
            event int mtxRow4Source                 [[ name: "Mtx Row 4 Src", min: 0, max: MtxSource::SIZE-1, step: 1, init: MtxSource::ENV1 ]];
            event float mtxRow4Multiplier           [[ name: "Mtx Row 4 Mult", min: -10, max: 10, step: .01, init: 1 ]];
            event int mtxRow4Dest1                  [[ name: "Mtx Row 4 Dest 1", min: 0, max: MtxDestination::SIZE-1, step: 1, init: 0 ]];
            event int mtxRow4Dest2                  [[ name: "Mtx Row 4 Dest 2", min: 0, max: MtxDestination::SIZE-1, step: 1, init: 0 ]];
            // Row 5
            event int mtxRow5Source                 [[ name: "Mtx Row 5 Src", min: 0, max: MtxSource::SIZE-1, step: 1, init: MtxSource::ENV2 ]];
            event float mtxRow5Multiplier           [[ name: "Mtx Row 5 Mult", min: -10, max: 10, step: .01, init: 1 ]];
            event int mtxRow5Dest1                  [[ name: "Mtx Row 5 Dest 1", min: 0, max: MtxDestination::SIZE-1, step: 1, init: 0 ]];
            event int mtxRow5Dest2                  [[ name: "Mtx Row 5 Dest 2", min: 0, max: MtxDestination::SIZE-1, step: 1, init: 0 ]];
            // Row 6
            event int mtxRow6Source                 [[ name: "Mtx Row 6 Src", min: 0, max: MtxSource::SIZE-1, step: 1, init: MtxSource::ENV3 ]];
            event float mtxRow6Multiplier           [[ name: "Mtx Row 6 Mult", min: -10, max: 10, step: .01, init: 1 ]];
            event int mtxRow6Dest1                  [[ name: "Mtx Row 6 Dest 1", min: 0, max: MtxDestination::SIZE-1, step: 1, init: 0 ]];
            event int mtxRow6Dest2                  [[ name: "Mtx Row 6 Dest 2", min: 0, max: MtxDestination::SIZE-1, step: 1, init: 0 ]];
            // Row 7
            event int mtxRow7Source                 [[ name: "Mtx Row 7 Src", min: 0, max: MtxSource::SIZE-1, step: 1, init: MtxSource::KEYTRACK ]];
            event float mtxRow7Multiplier           [[ name: "Mtx Row 7 Mult", min: -10, max: 10, step: .01, init: 1 ]];
            event int mtxRow7Dest1                  [[ name: "Mtx Row 7 Dest 1", min: 0, max: MtxDestination::SIZE-1, step: 1, init: 0 ]];
            event int mtxRow7Dest2                  [[ name: "Mtx Row 7 Dest 2", min: 0, max: MtxDestination::SIZE-1, step: 1, init: 0 ]];
            // Row 8
            event int mtxRow8Source                 [[ name: "Mtx Row 8 Src", min: 0, max: MtxSource::SIZE-1, step: 1, init:MtxSource::VELOCITY ]];
            event float mtxRow8Multiplier           [[ name: "Mtx Row 8 Mult", min: -10, max: 10, step: .01, init: 1 ]];
            event int mtxRow8Dest1                  [[ name: "Mtx Row 8 Dest 1", min: 0, max: MtxDestination::SIZE-1, step: 1, init: 0 ]];
            event int mtxRow8Dest2                  [[ name: "Mtx Row 8 Dest 2", min: 0, max: MtxDestination::SIZE-1, step: 1, init: 0 ]];

        }

        output {
            event Instrument::Params paramsOut;
            event Instrument::OscParams oscParamsOut;
            event Instrument::EnvParams envParamsOut;
            event Instrument::LfoParams lfoParamsOut;
            event Instrument::MtxSourceUpdate mtxSourceUpdateOut;
            event Instrument::MtxMultiplierUpdate mtxMultiplierUpdateOut;
            event Instrument::MtxDestination1Update mtxDest1UpdateOut;
            event Instrument::MtxDestination2Update mtxDest2UpdateOut;            

            event float stereoSpreadOut;
            event float chorusAmountOut;
        }

        Instrument::Params params = createParams();
        Instrument::OscParams[3] oscParams = (createOscParams(0), createOscParams(1), createOscParams(2));
        Instrument::EnvParams[3] envParams = (createEnvParams(0), createEnvParams(1), createEnvParams(2));
        Instrument::LfoParams[3] lfoParams = (createLfoParams(0), createLfoParams(1), createLfoParams(2));

        Instrument::ParamOut paramOut;


        // Oscillator 1 events
        event osc1Transpose(float32 f) {
            oscParams.at(0).transpose = f;
            oscParamsOut <- oscParams.at(0);
        }
        event osc1Detune(int i) {
            oscParams.at(0).detune = float(i);
            oscParamsOut <- oscParams.at(0);
        }
        event osc1Gain(int i) {
            oscParams.at(0).gain = float(i) / 100.0f;
            oscParamsOut <- oscParams.at(0);
        }
        event osc1Waveshape(int i) {
            oscParams.at(0).waveshape = i;
            oscParamsOut <- oscParams.at(0);
        }
        event osc1Pan(int i) {
            oscParams.at(0).pan = i;
            oscParamsOut <- oscParams.at(0);
        }
        event osc1Saturation(int i) {
            oscParams.at(0).saturation = float(i) / 100.0f;
            oscParamsOut <- oscParams.at(0);
        }
        event osc1SaturationType(int i) {
            oscParams.at(0).saturationType = i;
            oscParamsOut <- oscParams.at(0);
        }
        
        // Oscillator 2 events
        event osc2Transpose(float32 f) {
            oscParams.at(1).transpose = f;
            oscParamsOut <- oscParams.at(1);
        }
        event osc2Detune(int i) {
            oscParams.at(1).detune = float(i);
            oscParamsOut <- oscParams.at(1);
        }
        event osc2Gain(int i) {
            oscParams.at(1).gain = float(i) / 100.0f;
            oscParamsOut <- oscParams.at(1);
        }
        event osc2Waveshape(int i) {
            oscParams.at(1).waveshape = i;
            oscParamsOut <- oscParams.at(1);
        }
        event osc2Sync(int i) {
            oscParams.at(1).sync = i;
            oscParamsOut <- oscParams.at(1);
        }
        event osc2Pan(int i) {
            oscParams.at(1).pan = i;
            oscParamsOut <- oscParams.at(1);
        }
        event osc2Saturation(int i) {
            oscParams.at(1).saturation = float(i) / 100.0f;
            oscParamsOut <- oscParams.at(1);
        }
        event osc2SaturationType(int i) {
            oscParams.at(1).saturationType = i;
            oscParamsOut <- oscParams.at(1);
        }
        
        // Oscillator 3 events
        event osc3Transpose(float32 f) {
            oscParams.at(2).transpose = f;
            oscParamsOut <- oscParams.at(2);
        }
        event osc3Detune(int i) {
            oscParams.at(2).detune = float(i);
            oscParamsOut <- oscParams.at(2);
        }
        event osc3Gain(int i) {
            oscParams.at(2).gain = float(i) / 100.0f;
            oscParamsOut <- oscParams.at(2);
        }
        event osc3Waveshape(int i) {
            oscParams.at(2).waveshape = i;
            oscParamsOut <- oscParams.at(2);
        }
        event osc3Pan(int i) {
            oscParams.at(2).pan = i;
            oscParamsOut <- oscParams.at(2);
        }
        event osc3Saturation(int i) {
            oscParams.at(2).saturation = float(i) / 100.0f;
            oscParamsOut <- oscParams.at(2);
        }
        event osc3SaturationType(int i) {
            oscParams.at(2).saturationType = i;
            oscParamsOut <- oscParams.at(2);
        }

        // Oscillator 3 Noise events
        event osc3NoiseAmount(int i) {
            params.osc3NoiseAmount = float(i) / 100.0f;
            paramsOut <- params;
        }
        event osc3NoiseType(int i) {
            params.osc3NoiseType = i;
            paramsOut <- params;
        }

        // Ring Modulation event
        event rmAmount(int i) {
            params.rmAmount = float(i) / 100.0f;
            paramsOut <- params;
        }
        
        // Filter events
        event filterCutoff(int i) {
            params.filterCutoff = float(i);
            paramsOut <- params;
        }
        event filterResonance(int i) {
            params.filterResonance = float(i) / 100.0f;  // 0-1000 -> 0.0-10.0
            paramsOut <- params;
        }
        event filterType(int i) {
            params.filterType = i;
            paramsOut <- params;
        }
        // Env 1 events
        event env1Attack(int i) {
            envParams.at(0).attack = float(i) / 1000.0f;
            envParamsOut <- envParams.at(0);
        }
        event env1Decay(int i) {
            envParams.at(0).decay = float(i) / 1000.0f;
            envParamsOut <- envParams.at(0);
        }
        event env1Sustain(int i) {
            envParams.at(0).sustain = float(i) / 100.0f;
            envParamsOut <- envParams.at(0);
        }
        event env1Release(int i) {
            envParams.at(0).release = float(i) / 1000.0f;
            envParamsOut <- envParams.at(0);
        }

        // Env 2 events
        event env2Attack(int i) {
            envParams.at(1).attack = float(i) / 1000.0f;
            envParamsOut <- envParams.at(1);
        }
        event env2Decay(int i) {
            envParams.at(1).decay = float(i) / 1000.0f;
            envParamsOut <- envParams.at(1);
        }
        event env2Sustain(int i) {
            envParams.at(1).sustain = float(i) / 100.0f;
            envParamsOut <- envParams.at(1);
        }
        event env2Release(int i) {
            envParams.at(1).release = float(i) / 1000.0f;
            envParamsOut <- envParams.at(1);
        }

        // Env 3 events
        event env3Attack(int i) {
            envParams.at(2).attack = float(i) / 1000.0f;
            envParamsOut <- envParams.at(2);
        }
        event env3Decay(int i) {
            envParams.at(2).decay = float(i) / 1000.0f;
            envParamsOut <- envParams.at(2);
        }
        event env3Sustain(int i) {
            envParams.at(2).sustain = float(i) / 100.0f;
            envParamsOut <- envParams.at(2);
        }
        event env3Release(int i) {
            envParams.at(2).release = float(i) / 1000.0f;
            envParamsOut <- envParams.at(2);
        }
        
        // Stereo Effects events
        event stereoSpread(int i) {
            params.stereoSpread = float(i) / 100.0f;
            stereoSpreadOut <- params.stereoSpread;
        }
        event chorusAmount(int i) {
            params.chorusAmount = float(i) / 100.0f;
            chorusAmountOut <- params.chorusAmount;
        }
       
        event mainGain(int i) {
            params.mainGain = float(i) / 100.0f;
            paramsOut <- params;
        }

        event lfo1Rate(int i) {
            lfoParams.at(0).rate = 0.1f + (float(i) / 100.0f) * 9.9f;  // 0.1 to 10 Hz
            lfoParamsOut <- lfoParams.at(0);
        }
        event lfo2Rate(int i) {
            lfoParams.at(1).rate = 0.1f + (float(i) / 100.0f) * 9.9f;  // 0.1 to 10 Hz
            lfoParamsOut <- lfoParams.at(1);
        }
        event lfo3Rate(int i) {
            lfoParams.at(2).rate = 0.1f + (float(i) / 100.0f) * 9.9f;  // 0.1 to 10 Hz
            lfoParamsOut <- lfoParams.at(2);
        }
        event lfo1Ramp(int i) {
            lfoParams.at(0).ramp = float(i) / 1000.0f;  // in seconds
            lfoParamsOut <- lfoParams.at(0);
        }
        event lfo2Ramp(int i) {
            lfoParams.at(1).ramp = float(i) / 1000.0f;  // in seconds
            lfoParamsOut <- lfoParams.at(1);
        }
        event lfo3Ramp(int i) {
            lfoParams.at(2).ramp = float(i) / 1000.0f;  // in seconds
            lfoParamsOut <- lfoParams.at(2);
        }
        event lfo1WaveShape(int i) {
            lfoParams.at(0).shape = i;
            lfoParamsOut <- lfoParams.at(0);
        }
        event lfo2WaveShape(int i) {
            lfoParams.at(1).shape = i;
            lfoParamsOut <- lfoParams.at(1);
        }
        event lfo3WaveShape(int i) {
            lfoParams.at(2).shape = i;
            lfoParamsOut <- lfoParams.at(2);
        }

        event mtxRow1Source(int32 i) {
            MtxSourceUpdate mtxUpdate;
            mtxUpdate.index = 1;
            mtxUpdate.source = i;
            mtxSourceUpdateOut <- mtxUpdate;
        }
        event mtxRow1Multiplier(float32 f) {
            MtxMultiplierUpdate mtxUpdate;
            mtxUpdate.index = 1;
            mtxUpdate.multiplier = f;
            mtxMultiplierUpdateOut <- mtxUpdate;
        }
        event mtxRow1Dest1(int32 i) {
            MtxDestination1Update mtxUpdate;
            mtxUpdate.index = 1;
            mtxUpdate.dest1 = i;
            mtxDest1UpdateOut <- mtxUpdate;
        }
        event mtxRow1Dest2(int32 i) {
            MtxDestination2Update mtxUpdate;
            mtxUpdate.index = 1;
            mtxUpdate.dest2 = i;
            mtxDest2UpdateOut <- mtxUpdate;
        }

        event mtxRow2Source(int32 i) {
            MtxSourceUpdate mtxUpdate;
            mtxUpdate.index = 2;
            mtxUpdate.source = i;
            mtxSourceUpdateOut <- mtxUpdate;
        }
        event mtxRow2Multiplier(float32 f) {
